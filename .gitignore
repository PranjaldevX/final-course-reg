# Root level gitignore for monorepo

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.sublime-*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Temporary files
*.tmp
*.temp
.cache/

# Build outputs (handled by subdirectory gitignores)
dist/
build/
